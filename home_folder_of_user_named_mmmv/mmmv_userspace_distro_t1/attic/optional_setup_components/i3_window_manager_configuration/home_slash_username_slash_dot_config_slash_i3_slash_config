bindsym $Win+Down  fullscreen toggle
bindsym $Win+Up    fullscreen toggle
bindsym $Win+space fullscreen toggle

bindsym $Win+Left  focus prev
bindsym $Win+Right focus next

# focus the parent or child container
# "i" like "in"
# "o" like "out"
bindsym $Win+o focus parent
bindsym $Win+i focus child

