bindsym $Win+F1 layout stacking
bindsym $Win+F2 layout tabbed
bindsym $Win+F3 layout toggle split

# split in vertical orientation
bindsym $Win+F4 split v

# split in horizontal orientation
bindsym $Win+F5 split h

